    ]
  },
  {
    "name": "recurring",
    "type": "base",
    "schema": [
      { "name": "type", "type": "select", "options": { "values": ["income","expense","transfer"] }, "required": true },
      { "name": "amount", "type": "number", "required": true },
      { "name": "currency", "type": "text", "required": true },
      { "name": "accountId", "type": "text", "required": true },
      { "name": "category", "type": "text" },
      { "name": "note", "type": "text" },
      { "name": "frequency", "type": "select", "options": { "values": ["daily","weekly","monthly","yearly"] }, "required": true },
      { "name": "startDate", "type": "text" },
      { "name": "endDate", "type": "text" }
    ]
  },
  {
    "name": "debts",
    "type": "base",
    "schema": [
      { "name": "person", "type": "text", "required": true },
      { "name": "amount", "type": "number", "required": true },
      { "name": "currency", "type": "text", "required": true },
      { "name": "description", "type": "text" },
