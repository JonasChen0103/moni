      { "name": "category", "type": "text" },
      { "name": "note", "type": "text" },
      { "name": "installmentId", "type": "text" }
    ]
  },
  {
    "name": "installments",
    "type": "base",
    "schema": [
      { "name": "accountId", "type": "text", "required": true },
      { "name": "description", "type": "text", "required": true },
      { "name": "principal", "type": "number", "required": true },
