[
  {
    "name": "accounts",
    "type": "base",
    "schema": [
      { "name": "name", "type": "text", "required": true },
      { "name": "type", "type": "select", "options": { "values": ["credit","checking","savings","debit","insurance","investment","cash","prepaid"] }, "required": true },
      { "name": "currency", "type": "text", "required": true },
      { "name": "balance", "type": "number" },
